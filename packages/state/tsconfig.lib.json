{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": ["node"],
    "paths": {
      "ng-primitives/state": ["dist/packages/ng-primitives/state"]
    }
  },
  "exclude": [
    "**/*.spec.ts",
    "test-setup.ts",
    "**/*.test.ts",
    "**/*.stories.ts",
    "**/*.stories.js"
  ],
  "include": ["**/*.ts"]
}
